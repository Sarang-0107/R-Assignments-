#1. inner_join()
#Find customers who have placed orders
#Match orders with product details, but only where both exist


outputs= customers %>% 
  inner_join(orders,by="customer_id" )

outputs


#left_join()
#Show all customers, including those who never ordered
#Attach product info to orders, even if some products are missing

never = left_join(customers,orders, by="customer_id")
never


# right_join()
#Show all products, even those never ordered
#Keep all entries from products table

all = right_join(orders,products, by="product_id")
all


#4. full_join()
#Combine customers and orders to see:
#  customers without orders
#orders without valid customers

result <- full_join(customers,orders, by= "customer_id")
result

#5. semi_join()
#Get customers who made at least one purchase
#Do NOT include order details
?semi_join
semi <- semi_join(customers,orders,by="customer_id")
semi


#6. anti_join()
#Find:
 # customers who never ordered
#orders with invalid customer_id

?anti_join

anti1 <- anti_join(customers,orders,by="customer_id")
anti1


anti2 <- anti_join(orders, customers, by = "customer_id")
anti2
