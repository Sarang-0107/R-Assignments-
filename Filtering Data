#16 FilteVSTEST#16 Filter abnormal vital signs results.
abnormal <- VS %>% 
  mutate(
    VSCLSIG = case_when(
      VSTEST == "Systolic Blood Pressure" & VSSTRESN > 140 ~ "Y",
      VSTEST == "Diastolic Blood Pressure" & VSSTRESN > 90 ~ "Y",
      VSTEST == "Temperature" & (VSSTRESN > 38 | VSSTRESN < 36) ~ "Y",
      VSTEST == "Heart Rate" & (VSSTRESN < 60 | VSSTRESN > 100) ~ "Y",
      TRUE ~ "N"
    )
  ) %>% 
  filter(VSCLSIG == "Y")
abnormal
view(abnormal)

#17 Filter subjects with increasing blood pressure compared to previous visit. Use lag().

Vital <- VS %>% 
  filter(VSTEST == "Systolic Blood Pressure") %>% 
  arrange(USUBJID,VISITNUM ) %>% 
  group_by(USUBJID) %>% 
  mutate(
    prev_SBP = lag(VSSTRESN),
    inc_SVP = if_else(VSSTRESN  > prev_SBP , "Y", "N")
  ) %>% 
  filter(inc_SVP == "Y")
Vital
view(Vital)

