# Top 5 Fastest Delivery Trucks Per City
#Each city tracks truck delivery times. Find the top 5 fastest trucks per city,
#including ties.

library(tibble)

transport <- tibble(
  truck_id = c(
    "T1","T2","T3","T4","T5","T6","T7","T8",
    "T1","T2","T3","T4","T5","T6","T7","T8",
    "T1","T2","T3","T4","T5","T6","T7","T8"
  ),
  city = c(
    rep("New York", 8),
    rep("Chicago", 8),
    rep("Los Angeles", 8)
  ),
  delivery_id = paste0("D", 1:24),
  delivery_time_minutes = c(
    30, 25, 25, 40, 20, 20, 35, 28,
    50, 45, 45, 60, 55, 40, 40, 42,
    35, 30, 28, 28, 25, 25, 40, 32
  )
)
transport

transport %>% group_by(city) %>% 
  mutate(Fastest_truck=dense_rank(delivery_time_minutes)) %>% 
  filter(Fastest_truck<=5)  
transport

